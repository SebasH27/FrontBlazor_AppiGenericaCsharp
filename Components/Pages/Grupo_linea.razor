@page "/grupo_linea"
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<h3>Relación Grupo - Línea de Investigación</h3>

@if (!string.IsNullOrEmpty(mensaje))
{
<div class="alert @(exito ? "alert-success" : "alert-danger")">
@mensaje </div>
}

<div class="card mb-3">
    <div class="card-body">

```
    <div class="row">

        <div class="col-md-6">
            <label>Grupo Investigación</label>
            <select class="form-select" @bind="grupoSeleccionado">
                <option value="0">Seleccione</option>
                @foreach (var g in grupos)
                {
                    <option value="@g["id"]">@g["nombre"]</option>
                }
            </select>
        </div>

        <div class="col-md-6">
            <label>Línea Investigación</label>
            <select class="form-select" @bind="lineaSeleccionada">
                <option value="0">Seleccione</option>
                @foreach (var l in lineas)
                {
                    <option value="@l["id"]">@l["nombre"]</option>
                }
            </select>
        </div>

    </div>

    <button class="btn btn-success mt-3" @onclick="AgregarRelacion">
        Agregar Relación
    </button>

</div>
```

</div>

@if (relaciones.Any())
{ <table class="table table-striped"> <thead> <tr> <th>Grupo</th> <th>Línea</th> <th>Acción</th> </tr> </thead> <tbody>
@foreach (var r in relaciones)
{ <tr> <td>@r["grupo_investigacion"]</td> <td>@r["linea_investigacion"]</td> <td>
<button class="btn btn-danger btn-sm"
@onclick="() => EliminarRelacion(r)">
Eliminar </button> </td> </tr>
} </tbody> </table>
}

@code {

private List<Dictionary<string, object?>> grupos = new();
private List<Dictionary<string, object?>> lineas = new();
private List<Dictionary<string, object?>> relaciones = new();

private int grupoSeleccionado = 0;
private int lineaSeleccionada = 0;

private string mensaje = "";
private bool exito = false;

protected override async Task OnInitializedAsync()
{
    grupos = await Api.ListarAsync("grupo_investigacion");
    lineas = await Api.ListarAsync("linea_investigacion");
    await CargarRelaciones();
}

private async Task CargarRelaciones()
{
    relaciones = await Api.ListarAsync("grupo_linea");
}

private async Task AgregarRelacion()
{
    var datos = new Dictionary<string, object?>
    {
        ["grupo_investigacion"] = grupoSeleccionado,
        ["linea_investigacion"] = lineaSeleccionada
    };

    var res = await Api.CrearAsync("grupo_linea", datos);

    exito = res.exito;
    mensaje = res.mensaje;

    if (exito)
        await CargarRelaciones();
}

private async Task EliminarRelacion(Dictionary<string, object?> r)
{
    var grupo = r["grupo_investigacion"]?.ToString();
    var linea = r["linea_investigacion"]?.ToString();

    // IMPORTANTE: PK compuesta
    var res = await Api.EliminarAsync(
        "grupo_linea",
        "grupo_investigacion",
        grupo!
    );

    exito = res.exito;
    mensaje = res.mensaje;

    if (exito)
        await CargarRelaciones();
}

}

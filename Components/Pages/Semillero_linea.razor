@code {

// ───────── LISTAS ─────────
private List<Dictionary<string, object?>> semilleros = new();
private List<Dictionary<string, object?>> lineas = new();
private List<Dictionary<string, object?>> relaciones = new();

// ───────── CAMPOS ─────────
private int semilleroSeleccionado = 0;
private int lineaSeleccionada = 0;

private string mensaje = "";
private bool exito = false;

private bool cargando = true;

// ───────── INICIO ─────────
protected override async Task OnInitializedAsync()
{
    await CargarDatos();
}

private async Task CargarDatos()
{
    cargando = true;

    semilleros = await Api.ListarAsync("semillero");
    lineas = await Api.ListarAsync("linea_investigacion");
    relaciones = await Api.ListarAsync("semillero_linea");

    cargando = false;
}

// ───────── CREAR RELACIÓN ─────────
private async Task AgregarRelacion()
{
    if (semilleroSeleccionado == 0 || lineaSeleccionada == 0)
    {
        mensaje = "Debe seleccionar ambos campos.";
        exito = false;
        return;
    }

    var datos = new Dictionary<string, object?>
    {
        ["semillero"] = semilleroSeleccionado,
        ["linea_investigacion"] = lineaSeleccionada
    };

    var res = await Api.CrearAsync("semillero_linea", datos);

    exito = res.exito;
    mensaje = res.mensaje;

    if (exito)
        await CargarDatos();
}

// ───────── ELIMINAR RELACIÓN ─────────
private async Task EliminarRelacion(Dictionary<string, object?> r)
{
    var semillero = r["semillero"]?.ToString();

    // ⚠️ IMPORTANTE: tu API probablemente solo elimina por una clave
    // (si no soporta PK compuesta)
    var res = await Api.EliminarAsync(
        "semillero_linea",
        "semillero",
        semillero!
    );

    exito = res.exito;
    mensaje = res.mensaje;

    if (exito)
        await CargarDatos();
}

}
